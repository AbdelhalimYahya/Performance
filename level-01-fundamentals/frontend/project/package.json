    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.18",
    "lighthouse": "^12.2.1",
    "prettier": "^3.4.1",
    "typescript": "^5.6.3",
    "webpack-bundle-analyzer": "^4.10.2"
