{
  "name": "perf-production-frontend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lhci:collect": "lhci collect --url=http://localhost:3000",
    "lhci:assert": "lhci assert",
    "lhci:upload": "lhci upload",
    "lhci:autorun": "lhci autorun",
    "perf:budget": "ts-node scripts/perf-budget.ts",
    "rum:analyze": "ts-node scripts/analyze-rum-data.ts",
    "bundle:check": "size-limit"
  },
  "dependencies": {
    "next": "^14.2.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "web-vitals": "^4.2.0",
    "@vercel/analytics": "^1.4.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/react": "^18.3.18",
    "@types/node": "^22.10.5",
    "eslint-config-next": "^14.2.21",
    "@lhci/cli": "^0.14.0",
    "size-limit": "^11.1.1",
    "@size-limit/preset-app": "^11.1.1",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2"
  },
  "size-limit": [
    {
      "name": "Initial Bundle (all pages)",
      "path": ".next/static/chunks/**/*.js",
      "limit": "200 KB"
    },
    {
      "name": "Per-Route Async Chunks",
      "path": ".next/static/chunks/pages/**/*.js",
      "limit": "80 KB",
      "warning": "60 KB"
    },
    {
      "name": "Framework Chunk",
      "path": ".next/static/chunks/framework-*.js",
      "limit": "150 KB"
    },
    {
      "name": "CSS Bundle",
      "path": ".next/static/css/*.css",
      "limit": "30 KB",
      "warning": "20 KB"
    }
  ]
}
