{
  "name": "perf-production-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Production monitoring backend with OpenTelemetry, Prometheus, and observability tooling",
  "scripts": {
    "build": "nest build",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:otel": "OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317 node dist/main",
    "metrics:test": "curl -s http://localhost:3000/metrics | head -50",
    "trace:view": "start http://localhost:16686",
    "health:check": "curl -s http://localhost:3000/health | python -m json.tool",
    "bench": "autocannon -c 100 -d 30 http://localhost:3000",
    "profile:heap": "node --heapsnapshot-signal=SIGUSR2 dist/main"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.1",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.1",
    "@nestjs/platform-express": "^10.3.1",
    "@nestjs/schedule": "^4.0.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/auto-instrumentations-node": "^0.41.0",
    "@opentelemetry/exporter-prometheus": "^0.45.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.45.0",
    "@opentelemetry/sdk-metrics": "^1.19.0",
    "@opentelemetry/sdk-node": "^0.45.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "opossum": "^8.1.4",
    "pino": "^8.17.2",
    "pino-http": "^9.0.0",
    "prom-client": "^15.1.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@types/node": "^20.11.5",
    "autocannon": "^7.14.0",
    "clinic": "^13.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
