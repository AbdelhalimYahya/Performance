{
  "name": "perf-advanced-frontend",
  "version": "1.0.0",
  "description": "Advanced frontend performance optimization — Next.js 14 + WASM + Bundle Analysis",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "analyze:server": "ANALYZE=server next build",
    "analyze:browser": "ANALYZE=browser next build",
    "bundle:report": "source-map-explorer .next/static/chunks/*.js --html bundle-report.html",
    "deps:check": "depcheck",
    "bundle:size": "node scripts/bundle-size-check.ts",
    "wasm:build": "wasm-pack build",
    "perf:trace": "node --cpu-prof --heap-prof next build"
  },
  "dependencies": {
    "next": "^14.2.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@next/bundle-analyzer": "^14.2.21",
    "sharp": "^0.33.5",
    "date-fns": "^4.1.0",
    "lodash-es": "^4.17.21",
    "comlink": "^4.4.2",
    "idb-keyval": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/node": "^22.10.5",
    "@types/lodash-es": "^4.17.12",
    "eslint-config-next": "^14.2.21",
    "prettier": "^3.4.2",
    "webpack-bundle-analyzer": "^4.10.2",
    "source-map-explorer": "^2.5.3",
    "depcheck": "^1.4.7",
    "size-limit": "^11.0.3",
    "@size-limit/preset-app": "^11.0.3"
  },
  "size-limit": [
    {
      "path": ".next/static/chunks/main*.js",
      "limit": "250 KB",
      "gzip": true
    },
    {
      "path": ".next/static/chunks/pages/**/*.js",
      "limit": "100 KB",
      "gzip": true
    }
  ],
  "engines": {
    "node": ">= 20"
  }
}
