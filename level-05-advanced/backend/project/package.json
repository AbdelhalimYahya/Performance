{
  "name": "perf-advanced-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nodemon --inspect --exec \"ts-node -r tsconfig-paths/register\" src/main.ts",
    "start:prod": "node dist/main",
    "start:cluster": "node dist/cluster.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "workers:test": "ts-node src/workers/worker-test.ts",
    "queue:dashboard": "ts-node src/bull-board.ts",
    "bench": "ts-node scripts/benchmark.ts",
    "bench:grpc": "ts-node scripts/bench-grpc.ts",
    "profile:cpu": "node --cpu-prof -r ts-node/register src/main.ts",
    "clinic:doctor": "clinic doctor -- node dist/main.js",
    "clinic:flame": "clinic flame -- node dist/main.js",
    "proto:gen": "protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/generated --ts_proto_opt=nestJs=true protos/*.proto",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/microservices": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/bull": "^10.2.3",
    "@grpc/grpc-js": "^1.12.5",
    "@grpc/proto-loader": "^0.7.13",
    "protobufjs": "^7.4.0",
    "bull": "^4.16.5",
    "piscina": "^4.7.0",
    "ioredis": "^5.4.2",
    "compression": "^1.7.5",
    "helmet": "^8.0.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@bull-board/api": "^5.21.4",
    "@bull-board/express": "^5.21.4",
    "@types/bull": "^4.10.1",
    "@types/compression": "^1.7.5",
    "@types/node": "^22.10.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "nodemon": "^3.1.9",
    "autocannon": "^7.16.0",
    "clinic": "^13.0.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2"
  }
}
