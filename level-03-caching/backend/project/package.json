{
  "name": "perf-caching-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "bench": "autocannon -c 100 -d 10 http://localhost:3000/api/products",
    "cache:flush": "redis-cli FLUSHDB",
    "cache:stats": "node scripts/cache-stats.js",
    "redis:start": "docker run -d --name redis-cache -p 6379:6379 redis:7-alpine"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/cache-manager": "^2.2.0",
    "cache-manager": "^5.4.0",
    "cache-manager-ioredis-yet": "^5.0.0",
    "ioredis": "^5.4.1",
    "@nestjs/config": "^3.2.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/event-emitter": "^2.0.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "lru-cache": "^10.4.3",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "typescript": "^5.7.2",
    "ts-node": "^10.9.2",
    "autocannon": "^7.16.0",
    "@types/node": "^22.10.2",
    "@types/express": "^4.17.21",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2"
  }
}
