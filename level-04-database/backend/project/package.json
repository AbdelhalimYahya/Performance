{
  "name": "perf-database-backend",
  "version": "1.0.0",
  "description": "Database performance optimization — NestJS + PostgreSQL + Prisma + Redis caching + DataLoader",
  "scripts": {
    "build": "nest build",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:analyze": "ts-node scripts/analyze-queries.ts",
    "db:explain": "ts-node scripts/explain-plan.ts",
    "bench": "autocannon -c 10 -d 30 http://localhost:4000/api/products?category=electronics",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/dataloader": "^1.0.2",
    "@prisma/client": "^6.2.0",
    "cache-manager": "^5.0.1",
    "cache-manager-ioredis-yet": "^5.0.0",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "dataloader": "^2.2.3",
    "compression": "^1.7.5",
    "helmet": "^8.0.0",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "prisma": "^6.2.0",
    "typescript": "^5.7.3",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.2.5",
    "jest": "^29.7.0",
    "@types/node": "^22.10.5",
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.11",
    "@types/dataloader": "^2.2.32",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "autocannon": "^7.16.0"
  },
  "engines": {
    "node": ">= 20"
  }
}
