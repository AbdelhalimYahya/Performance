# PostgreSQL connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/perf_database

# Application
PORT=4000
NODE_ENV=development

# Connection Pool (tuned for 4-core server)
# Formula: max = (CPU cores × 2) + spindle_count
# For 4-core SSD: (4 × 2) + 1 = 9, rounded to 20 for headroom
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# Read Replicas (configure when ready)
# DB_READ_HOST=replica-1.example.com
# DB_READ_PORT=5432
